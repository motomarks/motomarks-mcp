{
  "name": "@motomarks/mcp",
  "version": "0.1.2",
  "description": "MCP server for Motomarks brand search, brand assets, and image CDN URLs.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/motomarks/motomarks-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/motomarks/motomarks-mcp/issues"
  },
  "homepage": "https://github.com/motomarks/motomarks-mcp#readme",
  "bin": {
    "motomarks-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepack": "npm run build",
    "test:integration": "tsx test/integration-smoke.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "motomarks",
    "logos",
    "brand-assets",
    "typescript"
  ],
  "author": "Adrian Ciaschetti",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "directories": {
    "test": "test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
