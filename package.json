{
  "name": "motomarks-mcp",
  "version": "0.1.0",
  "description": "MCP server for Motomarks brand search, brand assets, and image CDN URLs.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/martini-studio/motomarks-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/martini-studio/motomarks-mcp/issues"
  },
  "homepage": "https://github.com/martini-studio/motomarks-mcp#readme",
  "bin": {
    "motomarks-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
